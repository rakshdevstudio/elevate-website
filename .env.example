# X Elevators Website — Environment Variables
# Copy this file to .env and fill in your Supabase project credentials

VITE_SUPABASE_URL="https://your-project-id.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# Website analytics dashboard ingestion
# Configure a Vercel Web Analytics Drain to POST into /api/vercel/analytics-drain
VERCEL_ANALYTICS_PROJECT_ID="prj_xxxxxxxxxxxxx"
VERCEL_ANALYTICS_OWNER_ID="team_xxxxxxxxxxxxx"
VERCEL_ANALYTICS_DRAIN_SECRET="XelevatorsAnalytics2026@secure"
WEBSITE_ANALYTICS_TIMEZONE="Asia/Kolkata"